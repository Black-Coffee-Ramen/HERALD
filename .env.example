# HERALD Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Authentication
API_TOKEN=super_secret_token_1234
JWT_SECRET_KEY=change_this_to_a_random_hex_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
POSTGRES_URL=postgresql://user:password@localhost:5432/herald

# Cache / Job Queue
REDIS_URL=redis://localhost:6379

# Dashboard (Streamlit)
DASHBOARD_SECRET=changeme

# Real-time CT log monitoring (default is the public Certstream relay)
CERTSTREAM_URL=wss://certstream.calidog.io

# Optional: Set to 1 to run without a GPU (EasyOCR will use CPU)
# FORCE_CPU=1
